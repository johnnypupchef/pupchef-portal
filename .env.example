# Portal public URL — magic links + Android App Links host (must match AndroidManifest intent-filter).
VITE_PORTAL_URL=https://my.pupchef.ae

# Public marketing site (header/footer links, Build Your Plan). Defaults to https://pupchef.ae
VITE_MARKETING_ORIGIN=https://pupchef.ae

# PupOps API (Next.js app). For local web dev use localhost; the native app ignores
# localhost here and uses https://pup-ops.vercel.app (emulator localhost is not your PC).
VITE_API_URL=http://localhost:3000

# Supabase Auth (anon key only — safe in browser). Same project as PupOps DB.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=
